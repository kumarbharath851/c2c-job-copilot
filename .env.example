# ── AWS Configuration ─────────────────────────────────────────────────────
AWS_REGION=us-east-1

# ── DynamoDB ──────────────────────────────────────────────────────────────
DYNAMODB_TABLE_NAME=c2c-job-copilot

# ── S3 ────────────────────────────────────────────────────────────────────
S3_BUCKET_NAME=c2c-job-copilot-files
S3_RESUME_PREFIX=resumes/

# ── AWS Bedrock ───────────────────────────────────────────────────────────
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# ── NextAuth ──────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=<generate with: openssl rand -base64 32>

# ── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=C2C Job Copilot

# ── SQS (optional — for async processing) ────────────────────────────────
# SQS_INGEST_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/<account>/c2c-ingest-queue
# SQS_TAILOR_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/<account>/c2c-tailor-queue

# ── Email digest (optional — SES) ────────────────────────────────────────
# SES_FROM_ADDRESS=alerts@c2ccopilot.com

# ── Cloudflare (deployment only) ─────────────────────────────────────────
# CLOUDFLARE_ZONE_ID=...
# CLOUDFLARE_API_TOKEN=...

# NOTE: Never commit real values. This file is safe to commit.
#       Copy to .env.local and fill in your actual values.
