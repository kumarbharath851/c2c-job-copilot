# ── Dependencies ────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Next.js ─────────────────────────────────────────────────────────────────
# next-env.d.ts is auto-generated by Next.js — never commit
.next/
out/
build/
next-env.d.ts

# ── TypeScript ───────────────────────────────────────────────────────────────
# *.d.ts covers generated declaration files (next-env.d.ts, CDK outputs)
*.tsbuildinfo
*.d.ts

# ── Environment / Secrets ────────────────────────────────────────────────────
# NEVER commit real credentials — use .env.example as documentation
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Test / Coverage ──────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── Build outputs ────────────────────────────────────────────────────────────
dist/
storybook-static/

# ── AWS ──────────────────────────────────────────────────────────────────────
# CDK synthesis output
cdk.out/
# Amplify CLI local state
.amplify/

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Claude Code temp files ───────────────────────────────────────────────────
# Files and dirs created by Claude Code CLI sessions
tmpclaude-*-cwd
tmpclaude-*-cwd/
tmp/

# ── Misc ─────────────────────────────────────────────────────────────────────
*.bak
*.orig
.turbo/
